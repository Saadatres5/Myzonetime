# MyZoneTime — Hostinger Node.js .htaccess
# This file configures Apache to proxy requests to the Node.js Express server.
# Hostinger's Node.js hosting uses Apache as a reverse proxy in front of Node.

Options -Indexes
DirectoryIndex disabled

<IfModule mod_rewrite.c>
  RewriteEngine On

  # If the request is for an existing file, serve it directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise proxy to Node.js
  RewriteRule ^(.*)$ http://localhost:%{ENV:PORT}/$1 [P,L]
</IfModule>

# Security headers (backup — also set in Express)
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-XSS-Protection "1; mode=block"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Gzip compression (backup)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>
