# ═══════════════════════════════════════════════════════════════════════════════
# MyZoneTime — Hostinger Node.js .htaccess
#
# IMPORTANT: Hostinger Node.js hosting does NOT support mod_proxy.
# This file handles ONLY HTTPS + non-www redirects at the Apache/LiteSpeed layer.
# All other routing (SPA, sitemaps, API) is handled by server.js (Express).
# DO NOT add RewriteRule [P,L] proxy rules — they cause 403 errors on Hostinger.
# ═══════════════════════════════════════════════════════════════════════════════

Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On

  # ── 1. Force HTTPS (301 permanent) ─────────────────────────────────────────
  # Catches http:// → https://
  # Without this, Google indexes http:// as a separate site, splitting authority.
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # ── 2. Force non-www canonical (301 permanent) ──────────────────────────────
  # www.myzonetime.com → myzonetime.com
  # Prevents duplicate content (www vs non-www) from splitting PageRank.
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

</IfModule>

# ── Security headers ──────────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options    "nosniff"
  Header always set X-Frame-Options           "SAMEORIGIN"
  Header always set Referrer-Policy           "strict-origin-when-cross-origin"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
</IfModule>
