# ═══════════════════════════════════════════════════════════════════════════════
# MyZoneTime — .htaccess (2026-07-22)
#
# Changes:
#  1. Added 301 redirects for old-format /time-difference/ URLs (no -and-)
#  2. All other rules unchanged
# ═══════════════════════════════════════════════════════════════════════════════

Options -Indexes
FileETag None

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Pass these files directly — no rewrites
  RewriteRule ^sitemap\.xml$                 - [L]
  RewriteRule ^sitemap-index\.xml$           - [L]
  RewriteRule ^city-sitemap\.xml$            - [L]
  RewriteRule ^timezone-sitemap\.xml$        - [L]
  RewriteRule ^time-difference-sitemap\.xml$ - [L]
  RewriteRule ^robots\.txt$                  - [L]
  RewriteRule ^ads\.txt$                     - [L]
  RewriteRule ^llms\.txt$                    - [L]

  # 1. Force HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

  # 2. Force non-www
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^ https://%1%{REQUEST_URI} [R=301,L]

  # 3. Remove trailing slash (except root)
  RewriteCond %{REQUEST_URI} ^/(.+)/$
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.+)/$ /$1 [R=301,L]

  # 4. Redirect old-format /time-difference/city1-city2 → canonical /time-difference/city1-and-city2
  RewriteRule ^time-difference/london-mumbai$        /time-difference/london-and-mumbai        [R=301,L]
  RewriteRule ^time-difference/amsterdam-london$     /time-difference/amsterdam-and-london     [R=301,L]
  RewriteRule ^time-difference/london-kuala-lumpur$  /time-difference/london-and-kuala-lumpur  [R=301,L]
  RewriteRule ^time-difference/los-angeles-london$   /time-difference/los-angeles-and-london   [R=301,L]
  RewriteRule ^time-difference/dubai-singapore$      /time-difference/dubai-and-singapore      [R=301,L]
  RewriteRule ^time-difference/istanbul-dubai$       /time-difference/istanbul-and-dubai       [R=301,L]
  RewriteRule ^time-difference/istanbul-london$      /time-difference/istanbul-and-london      [R=301,L]
  RewriteRule ^time-difference/istanbul-new-york$    /time-difference/istanbul-and-new-york    [R=301,L]
  RewriteRule ^time-difference/abu-dhabi-london$     /time-difference/abu-dhabi-and-london     [R=301,L]

  # 5. SPA fallback — serve index.html for all non-file, non-directory requests
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]

</IfModule>

# Security headers
<IfModule mod_headers.c>
  Header always set X-Content-Type-Options    "nosniff"
  Header always set X-Frame-Options           "SAMEORIGIN"
  Header always set Referrer-Policy           "strict-origin-when-cross-origin"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header always set Permissions-Policy        "camera=(), microphone=(), geolocation=(self)"
</IfModule>

# Browser caching
<IfModule mod_expires.c>
  ExpiresActive On
  <FilesMatch "\.(js|css|woff2|woff|ttf|svg|ico|png|jpg|jpeg|webp|avif)$">
    ExpiresDefault "access plus 1 year"
    Header append Cache-Control "public, immutable"
  </FilesMatch>
  <FilesMatch "\.(html)$">
    ExpiresDefault "access plus 5 minutes"
    Header set Cache-Control "public, max-age=300, stale-while-revalidate=86400"
  </FilesMatch>
  <FilesMatch "\.(xml|txt)$">
    ExpiresDefault "access plus 1 hour"
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
</IfModule>

# Gzip
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json application/xml text/xml text/plain
</IfModule>
